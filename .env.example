##
##   ******************IMPORTANT**********************
##   This file contains private enviromental variables
##   and should not be changed or shared.
##
##   Only update the variables that contain
##   text like "YOUR_API_KEY_HERE".
##
##   Do not modify the variables which
##   contain the comment "# DNM".
##
##   Once you have finished adding the tokens to this file,
##   rename the file to .env as .env.example is not valid
##
##   Any modifications to this file requires a full restart
##   of the helpdesk.
##
##

# Freshservice (Tickets)
FS_TOKEN=YOUR_FRESH_SERVICE_TOKEN
FS_URL=YOUR_FRESH_SERVICE_URL # example https://<your-subdomain>.freshservice.com/api/v2/tickets/filter
FS_WORKSPACE_ID=YOUR_WORKSPACE_ID

#
#   All modules can be toggled
#   off and on via the top of each module.
#
# UniFI Module (CCTV monitoring)
CCTV_ENABLED=true
CCTV_URL=YOUR_UNFI_CCTV_URL
CCTV_TOKEN=YOUR_CCTV_TOKEN
# Zabbix Module (Server and switch monitoring)
ZABBIX_ENABLED=false # zabbix is disabled by default, to enable replace with "true".
ZABBIX_TOKEN=YOUR_ZABBIX_TOKEN
ZABBIX_URL=YOUR_ZABBIX_URL
